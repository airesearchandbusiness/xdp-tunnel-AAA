# Tunnel Configuration Example
# Copy this file to '<YOUR_TUNNEL_NAME>.conf' and fill in your actual values.

[Interface]
# Generate a strong secret key for SHA256 hashing
PrivateKey = YOUR_SECRET_KEY_HERE
ListenPort = 443
VirtualIP = 10.8.0.1/24
LocalPhysicalIP = 192.168.1.10
PhysicalInterface = eth0
# MimicryType: 0 = Standard UDP, 1 = QUIC Mimicry
MimicryType = 1
EnableEncryption = true

[Peer]
# The public or local IP of the remote ghost node
EndpointIP = 192.168.1.20
# Remote node physical MAC address (Required for XDP redirect)
EndpointMAC = 00:00:00:00:00:00
# The Virtual IP assigned to the remote peer
InnerIP = 10.8.0.2