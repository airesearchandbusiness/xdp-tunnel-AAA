# Tachyon XDP Tunnel - Configuration Example
#
# Copy this to '<name>.conf' and fill in your values.
# Generate keys:
#   tachyon genkey                          -> private key (hex)
#   echo <private_key> | tachyon pubkey     -> public key (hex)

[Interface]
# X25519 private key (64 hex characters)
PrivateKey = YOUR_PRIVATE_KEY_HEX_HERE

# Peer's X25519 public key (64 hex characters)
PeerPublicKey = PEER_PUBLIC_KEY_HEX_HERE

# Optional pre-shared key for additional security
# PresharedKey = optional_psk_string

# UDP listen port (default: 443)
ListenPort = 443

# Virtual tunnel IP with subnet (assigned to local veth)
VirtualIP = 10.8.0.1/24

# Local physical IP (source for outer packets)
LocalPhysicalIP = 192.168.1.10

# Physical network interface for tunnel traffic
PhysicalInterface = eth0

# Traffic obfuscation: 0 = Standard UDP, 1 = QUIC Mimicry (default: 1)
MimicryType = 1

# Enable AEAD encryption (default: true)
EnableEncryption = true

# Traffic analysis resistance flags (bitmask, default: 0x3F = all enabled)
#   0x01 = TTL jitter (vary outer TTL 63-66, defeats OS fingerprinting)
#   0x02 = IP ID randomization (prevent cross-packet correlation)
#   0x04 = DF bit variation (probabilistic clearing, ~1/256 packets)
#   0x08 = DSCP stripping (zero inner QoS marks in outer header)
#   0x10 = Constant-size padding (all packets padded to MTU)
#   0x20 = Decoy chaff traffic (random keepalives during idle)
#   0x3F = All countermeasures active (maximum obfuscation)
#   0x00 = Disabled (for debugging / benchmarking)
ObfuscationFlags = 0x3F

[Peer]
# Remote node's physical IP address
EndpointIP = 192.168.1.20

# Remote node's physical MAC address (required for XDP L2 redirect)
EndpointMAC = aa:bb:cc:dd:ee:ff

# Virtual IP assigned to the remote peer (no subnet)
InnerIP = 10.8.0.2
